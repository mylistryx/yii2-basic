{
    "name": "mylistryx/yii2-basic",
    "description": "Yii 2 Basic Project Template",
    "keywords": ["yii2", "framework", "basic", "project template"],
    "homepage": "https://www.net23.ru/",
    "type": "project",
    "license": "BSD-3-Clause",
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.4.0",
        "yiisoft/yii2": "~2.0.52",
        "yiisoft/yii2-bootstrap5": "~2.0.50",
        "yiisoft/yii2-queue": "~2.3.7",
        "yiisoft/yii2-redis": "~2.0.20",
        "yiisoft/yii2-symfonymailer": "~2.0.4",
        "ramsey/uuid": ">=4.9.1"
    },
    "require-dev": {
        "yiisoft/yii2-debug": ">=2.1.0",
        "yiisoft/yii2-gii": ">=2.2.0",
        "yiisoft/yii2-faker": ">=2.0.0",
        "codeception/codeception": ">=5.0.0",
        "codeception/lib-innerbrowser": ">=4.0",
        "codeception/module-asserts": ">=3.0",
        "codeception/module-yii2": ">=1.1.12",
        "codeception/module-filesystem": ">=3.0.1",
        "codeception/verify": ">=3.3.0",
        "larapack/dd": ">=1.1"
    },
    "config": {
        "allow-plugins": {
            "yiisoft/yii2-composer" : true
        },
        "process-timeout": 1800,
        "fxp-asset": {
            "enabled": false
        }
    },
    "scripts": {
        "post-install-cmd": [
            "yii\\composer\\Installer::postInstall"
        ],
        "post-create-project-cmd": [
            "yii\\composer\\Installer::postCreateProject",
            "yii\\composer\\Installer::postInstall"
        ]
    },
    "extra": {
        "yii\\composer\\Installer::postCreateProject": {
            "setPermission": [
                {
                    "runtime": "0777",
                    "web/assets": "0777",
                    "yii": "0755"
                }
            ]
        },
        "yii\\composer\\Installer::postInstall": {
            "generateCookieValidationKey": [
                "config/web.php"
            ]
        }
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ]
}
